{
	"compilerOptions": {
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.server.tsbuildinfo",
		"target": "es2023",
		"module": "esnext",
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"lib": ["ES2023"],
		"types": ["node"],
		"skipLibCheck": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,
		"strict": true
	},
	"include": ["."]
}
