generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id       String @id
  email    String @unique
  nickname String @unique

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  gamesCreated Game[] @relation(name: "gamesCreated")
  gamesJoined  Game[] @relation(name: "gamesJoined")
  games        Game[]

  @@map("users")
}

model Game {
  id        String @id @default(cuid())
  name      String
  size      Int
  toWin     Int    @map("to_win")
  creator   User   @relation(fields: [creatorId], references: [id], name: "gamesCreated")
  creatorId String @map("creator_id")

  opponent   User?   @relation(fields: [opponentId], references: [id], name: "gamesJoined")
  opponentId String? @map("opponent_id")

  creatorSymbol String @map("creator_symbol")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  state           String?
  currentPlayer   User?   @relation(fields: [currentPlayerId], references: [id])
  currentPlayerId String? @map("current_player_id")

  @@map("games")
}
