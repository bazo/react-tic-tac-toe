generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id       String @id
  email    String @unique
  nickname String @unique

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  roomsCreated Room[] @relation(name: "roomsCreated")
  roomsJoined  Room[] @relation(name: "roomsJoined")

  @@map("users")
}

model Room {
  id        String @id @default(cuid())
  name      String
  size      Int
  toWin     Int    @map("to_win")
  creator   User   @relation(fields: [creatorId], references: [id], name: "roomsCreated")
  creatorId String @map("creator_id")

  opponent   User?   @relation(fields: [opponentId], references: [id], name: "roomsJoined")
  opponentId String? @map("opponent_id")

  creatorSymbol String @map("creator_symbol")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("rooms")
}
